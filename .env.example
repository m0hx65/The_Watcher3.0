# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
TELEGRAM_ADMIN_IDS=111111111,222222222

# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/watcher

# Instagram
IG_APP_ID=936619743392459
IG_SESSION_COOKIE=

# Scheduler
CHECK_INTERVAL=1800
JITTER_SECONDS=120
REQUEST_TIMEOUT=20
MAX_CONCURRENT_FETCHES=3

# Storage
MEDIA_DIR=./data/media

# Logging
LOG_LEVEL=INFO

# Optional outbound proxy (single URL — applied to both http and https)
PROXY_URL=
# Legacy aliases also recognized (PROXY_URL wins if set)
HTTP_PROXY=
HTTPS_PROXY=

# Optional Web API auth
WEB_API_TOKEN=
