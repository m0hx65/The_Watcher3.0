# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCDEF_your_bot_token_here
TELEGRAM_CHAT_ID=-1001234567890
# Comma-separated Telegram user IDs allowed to use the bot. Leave empty to allow all.
TELEGRAM_ADMIN_IDS=111111111,222222222
# Public base URL for webhook registration (e.g. https://your-app.onrender.com).
# Leave empty to use long polling (recommended for local development).
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# ── Database ───────────────────────────────────────────────────────────────────
# Any Postgres URL works — postgres://, postgresql://, or postgresql+asyncpg://
# are all normalized for the asyncpg driver automatically. A Neon or Supabase
# connection string can be pasted verbatim, including its ?sslmode=require&
# channel_binding=require suffix (translated to asyncpg's ssl= param for you).
# Neon free tier is recommended — unlike Render's free DB it does not expire.
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/watcher

# ── Scheduler ─────────────────────────────────────────────────────────────────
CHECK_INTERVAL=1800
JITTER_SECONDS=120
REQUEST_TIMEOUT=20
MAX_CONCURRENT_FETCHES=3
# Sweep pacing + 401 circuit breaker. The gap between account launches widens as
# consecutive 401/403 blocks pile up (up to the max); once this many happen in a
# row the breaker defers the rest of the sweep to the retry pass / next sweep so
# a burst can't snowball. Set the threshold to 0 to disable the breaker.
SWEEP_STAGGER_MAX_SECONDS=12
SWEEP_BREAKER_THRESHOLD=5

# ── Stakeout & Radar ───────────────────────────────────────────────────────────
# Stakeout = temporary high-frequency watch on one target. The min interval sits
# above the 90s reel cache so every tick is fresh without risking 401s.
STAKEOUT_DEFAULT_INTERVAL=180
STAKEOUT_MIN_INTERVAL=120
STAKEOUT_DEFAULT_DURATION=3600
STAKEOUT_MAX_DURATION=21600
# Flag a target after this many days with no story/post/reel. 0 disables.
DARK_RADAR_DAYS=3

# Follower-anomaly alert: fires only when a follower change is large in BOTH
# absolute (≥ abs) and relative (≥ pct of prior count) terms, so it ignores a
# small account's noise and a big account's normal drift. Either 0 disables it.
FOLLOWER_ANOMALY_ABS_MIN=500
FOLLOWER_ANOMALY_PCT_MIN=0.10

# Digest roll-up. The mode (off/daily/weekly) is toggled at runtime with the
# /digest command; these only set WHEN a scheduled digest fires. Daily goes out
# every day at DIGEST_HOUR (UTC); weekly only on DIGEST_WEEKDAY (0=Monday).
DIGEST_HOUR=9
DIGEST_WEEKDAY=0

# Give each monitored account its own forum topic (thread) when the chat is a
# Topics-enabled group and the bot is an admin with "Manage topics". Global
# messages stay in General. Off by default (everything goes to one chat).
TELEGRAM_FORUM_TOPICS=false
# Mirror a flat copy of every notification to extra chats (comma-separated).
# Handy to get alerts in your DM too while TELEGRAM_CHAT_ID is the forum group.
# Mirrors never use topics (DMs/non-forum chats can't). Empty = no mirroring.
# TELEGRAM_MIRROR_CHAT_IDS=930123749

# ── Storage & Retention ────────────────────────────────────────────────────────
MEDIA_DIR=./data/media
# Days to retain data. Set to 0 to keep forever.
SNAPSHOT_RETENTION_DAYS=30
NOTIFICATION_RETENTION_DAYS=90
RAW_RESPONSE_RETENTION_DAYS=7
# Downloaded story/post files older than this are deleted by the daily cleanup
# (already delivered to Telegram; on-demand requests re-download). 0 = keep all.
MEDIA_RETENTION_DAYS=14

# ── Instagram ─────────────────────────────────────────────────────────────────
# Optional: Instagram sessionid cookie for authenticated requests.
IG_SESSION_COOKIE=
# Optional: proxy used specifically for Instagram requests.
IG_PROXY_URL=

# ── Proxy (general outbound) ──────────────────────────────────────────────────
# PROXY_URL wins over HTTP_PROXY / HTTPS_PROXY when set.
PROXY_URL=
HTTP_PROXY=
HTTPS_PROXY=

# ── Web API ───────────────────────────────────────────────────────────────────
# If set, required as X-API-Token header for /sweep and /accounts/*/recheck.
WEB_API_TOKEN=

# ── Runtime ───────────────────────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
